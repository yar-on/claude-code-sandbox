{
    "name": "@claude-code-sandbox/cli",
    "version": "0.6.2",
    "description": "CLI for managing the claude-code-sandbox Docker container",
    "keywords": [
        "claude",
        "claude-code",
        "anthropic",
        "sandbox",
        "docker",
        "cli"
    ],
    "homepage": "https://github.com/spiriyu/claude-code-sandbox",
    "repository": {
        "type": "git",
        "url": "https://github.com/spiriyu/claude-code-sandbox.git"
    },
    "license": "MIT",
    "type": "module",
    "bin": {
        "claude-code-sandbox": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "build:watch": "tsup --watch",
        "dev": "tsx src/cli.ts",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "archiver": "7.0.1",
        "chalk": "^5.3.0",
        "commander": "^12.1.0",
        "dockerode": "^4.0.2",
        "inquirer": "^12.3.0",
        "ora": "^8.1.1",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@claude-code-sandbox/shared": "*",
        "@types/archiver": "7.0.0",
        "@types/dockerode": "^3.3.32",
        "@types/node": "^22.0.0",
        "tsup": "^8.3.0",
        "tsx": "^4.21.0",
        "typescript": "^5.6.0",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
