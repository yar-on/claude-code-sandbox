{
    "name": "@spiriyu/claude-code-sandbox-docker",
    "version": "0.5.1",
    "private": true,
    "description": "Docker image for claude-code-sandbox",
    "scripts": {
        "build": "docker build -f image/Dockerfile --build-arg USER_UID=$(id -u) --build-arg USER_GID=$(id -g) -t claude-code-sandbox .",
        "generate-matrix": "node scripts/generate-matrix.js",
        "generate-readme": "node scripts/generate-readme.js",
        "release": "cd ../.. && release-it"
    },
    "license": "MIT",
    "devDependencies": {
        "@claude-code-sandbox/shared": "*"
    }
}
